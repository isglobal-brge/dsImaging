#!/bin/sh
# dsImaging post-install configuration script
# Runs automatically during R CMD INSTALL on Unix systems.
#
# Creates a minimal Python venv for dsImaging utilities (fingerprinting).
# Only stdlib is needed -- no pip deps. Just Python itself.
#
# Self-contained: downloads uv if not present, uv installs Python.

VENV_ROOT="${DSIMAGING_VENV_ROOT:-/var/lib/dsimaging}"
LOG_PREFIX="[dsImaging configure]"

log_info() { echo "${LOG_PREFIX} $*"; }
log_warn() { echo "${LOG_PREFIX} WARNING: $*" >&2; }

# ---------------------------------------------------------------------------
# Bootstrap: ensure uv + Python
# ---------------------------------------------------------------------------

ensure_uv() {
  UV="$(command -v uv 2>/dev/null || true)"
  if [ -n "${UV}" ] && [ -x "${UV}" ]; then return 0; fi

  for _p in "${HOME}/.local/bin/uv" "${HOME}/.cargo/bin/uv" "/usr/local/bin/uv"; do
    if [ -x "${_p}" ]; then UV="${_p}"; return 0; fi
  done

  log_info "Downloading uv..."

  if command -v curl >/dev/null 2>&1; then
    _DL="curl -LsSf"
  elif command -v wget >/dev/null 2>&1; then
    _DL="wget -qO-"
  else
    if command -v apt-get >/dev/null 2>&1; then
      apt-get update -qq 2>/dev/null && apt-get install -y -qq curl 2>/dev/null
      _DL="curl -LsSf"
    elif command -v apk >/dev/null 2>&1; then
      apk add --no-cache curl 2>/dev/null
      _DL="curl -LsSf"
    else
      log_warn "No curl/wget. Cannot download uv."
      return 1
    fi
  fi

  ${_DL} https://astral.sh/uv/install.sh 2>/dev/null | sh 2>/dev/null
  UV="${HOME}/.local/bin/uv"
  if [ ! -x "${UV}" ]; then UV="$(command -v uv 2>/dev/null || true)"; fi
  if [ -n "${UV}" ] && [ -x "${UV}" ]; then
    log_info "uv installed: $(${UV} --version)"
    return 0
  fi
  log_warn "Failed to install uv."
  return 1
}

ensure_python_venv() {
  local venv_path="${VENV_ROOT}/venv"

  if [ -d "${venv_path}" ] && [ -x "${venv_path}/bin/python" ]; then
    log_info "Python venv: OK (cached)"
    return 0
  fi

  if [ -z "${UV}" ] || [ ! -x "${UV}" ]; then
    log_warn "No uv. Cannot create Python venv."
    return 1
  fi

  log_info "Creating Python venv..."
  mkdir -p "${VENV_ROOT}" 2>/dev/null || {
    log_warn "Cannot create ${VENV_ROOT}. Skipping."
    return 1
  }

  rm -rf "${venv_path}"
  "${UV}" venv --python 3.11 --quiet "${venv_path}" 2>&1

  if [ -x "${venv_path}/bin/python" ]; then
    log_info "Python venv ready: ${venv_path}/bin/python"
    log_info "  $("${venv_path}/bin/python" --version 2>&1)"
    return 0
  fi

  log_warn "Failed to create Python venv."
  return 1
}

# ---------------------------------------------------------------------------
# Ensure R dependencies (resourcer, aws.s3) are installed
# ---------------------------------------------------------------------------

ensure_r_deps() {
  log_info "Checking R dependencies..."
  # Determine Rock's library path
  ROCK_LIB="/var/lib/rock/R/library"
  if [ ! -d "${ROCK_LIB}" ]; then
    ROCK_LIB=""  # not on Rock, skip
    return 0
  fi

  for pkg in DBI RSQLite digest yaml jsonlite resourcer R6 aws.s3 arrow; do
    Rscript --vanilla -e "
      if (!requireNamespace('${pkg}', quietly=TRUE, lib.loc='${ROCK_LIB}')) {
        cat('Installing ${pkg}...\n')
        install.packages('${pkg}', lib='${ROCK_LIB}', repos='https://cloud.r-project.org', quiet=TRUE)
      }
    " 2>/dev/null
  done
  log_info "R dependencies OK"
}

# ---------------------------------------------------------------------------
# Register dsImaging resolver in Rserve profile (Rock only)
# ---------------------------------------------------------------------------

ensure_rprofile() {
  RPROFILE="/srv/conf/Rprofile.R"
  if [ ! -f "${RPROFILE}" ]; then return 0; fi
  if grep -q "dsImaging" "${RPROFILE}" 2>/dev/null; then return 0; fi

  log_info "Adding dsImaging resolver to Rserve profile..."
  cat >> "${RPROFILE}" << 'REOF'

# dsImaging: register resource resolver for imaging+dataset:// URLs
tryCatch(loadNamespace("dsImaging"), error = function(e) NULL)
REOF
  log_info "Rserve profile updated"
}

# ---------------------------------------------------------------------------
# Fix Python permissions (Rock runs as non-root 'rock' user)
# ---------------------------------------------------------------------------

fix_python_permissions() {
  if [ -d "/root/.local/share/uv/python" ]; then
    chmod -R 755 /root/.local/share/uv/python/ 2>/dev/null
    chmod 755 /root /root/.local /root/.local/share /root/.local/share/uv 2>/dev/null
    log_info "Python permissions fixed for rock user"
  fi
}

# --- Run ---

ensure_r_deps
ensure_uv || {
  log_warn "uv not available. dsImaging will try to provision Python at runtime."
  exit 0
}

ensure_python_venv || {
  log_warn "Python venv not created. dsImaging will try at runtime."
  exit 0
}

fix_python_permissions
ensure_rprofile
log_info "dsImaging setup complete."
exit 0
